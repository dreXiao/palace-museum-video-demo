# 故宫日历·图生视频管理平台 环境变量
# 复制为 .env 并修改为你自己的值

# ── 应用 ──
APP_NAME=故宫日历·图生视频管理平台
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=change-me-to-a-random-64-character-string

# ── 数据库 ──
DATABASE_URL=postgresql+asyncpg://palace:palace@postgres:5432/palace_museum
REDIS_URL=redis://redis:6379/0
DB_PASSWORD=palace

# ── JWT ──
JWT_SECRET_KEY=change-me-jwt-secret-key-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── 初始管理员 ──
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ── 对象存储 (MinIO) ──
STORAGE_ENDPOINT=http://minio:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=palace-museum-media
STORAGE_USE_SSL=false

# ── AI API Keys (请替换为真实密钥) ──
DASHSCOPE_API_KEY=sk-your-dashscope-key-here
SEEDANCE_API_KEY=sk-your-seedance-key-here
KLING_API_KEY=sk-your-kling-access-key
KLING_API_SECRET=sk-your-kling-secret-key

# ── CORS ──
CORS_ORIGINS=http://localhost:5173,http://localhost

# ── 速率限制 ──
RATE_LIMIT_GENERATION=10/minute
